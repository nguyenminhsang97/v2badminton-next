# V2 Badminton Next - Local / Preview env template
# Copy to `.env.local` for local work, or to your preview environment settings.

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SITE_URL=https://v2badminton.com
# Optional. Keep empty while dataset is public.
SANITY_API_READ_TOKEN=
# Sprint 2 uses time-based ISR for Sanity reads.
SANITY_REVALIDATE_SECONDS=300

# Core save-first lead pipeline
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
FORM_TOKEN_SECRET=

# Telegram lead notify
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email notify
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
# Required for production deliverability. Preview may fall back to Resend sandbox.
NOTIFY_EMAIL_FROM=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Rate limit
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry baseline
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Internal preview-only monitoring helpers
ENABLE_MONITORING_TEST_ROUTES=false

# Ops / alerting
# Optional. If set with TELEGRAM_BOT_TOKEN, degraded integrations can ping ops chat.
TELEGRAM_OPS_CHAT_ID=
